# Kalshi Weather Arb Bot — Environment Variables
# Copy to .env and fill in values

# ── Kalshi API ────────────────────────────────────────────
KALSHI_API_KEY_ID=
# Option A: path to PEM file (local dev)
KALSHI_PRIVATE_KEY_PATH=~/.kalshi/private_key.pem
# Option B: inline PEM string (Railway / production)
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Discord ───────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Bot settings ──────────────────────────────────────────
# LIVE_TRADING=false means paper trading only — no real orders placed
# Set to true only when ready to go live (also set KALSHI_API_BASE_URL to prod)
LIVE_TRADING=false
INITIAL_BANKROLL=1000
KELLY_FRACTION=0.15
SCAN_INTERVAL_SECONDS=30
MIN_EDGE_THRESHOLD=0.08
KALSHI_FEE_RATE=0.07
WEATHER_MAX_TRADE_SIZE=100

# ── Dev convenience ───────────────────────────────────────
# Set CITY_OVERRIDE to scan only one city locally (e.g. CITY_OVERRIDE=nyc)
# CITY_OVERRIDE=

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./weatherbot.db

# ── Health check port ─────────────────────────────────────
PORT=8080
