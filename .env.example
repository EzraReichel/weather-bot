# Kalshi Weather Arb Bot — Environment Variables
# Copy to .env and fill in values

# ── Kalshi API ────────────────────────────────────────────
KALSHI_API_KEY_ID=
# Option A: path to PEM file (local dev)
KALSHI_PRIVATE_KEY_PATH=~/.kalshi/private_key.pem
# Option B: inline PEM string (Railway / production)
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Discord ───────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Bot settings ──────────────────────────────────────────
# DRY_RUN=true means fetch real data + send Discord alerts, but NEVER place orders
# Set to false only when you're ready to go live
DRY_RUN=true
SIMULATION_MODE=true
INITIAL_BANKROLL=1000
KELLY_FRACTION=0.15
SCAN_INTERVAL_SECONDS=30
MIN_EDGE_THRESHOLD=0.08
KALSHI_FEE_RATE=0.07
WEATHER_MAX_TRADE_SIZE=100

# ── Cities to scan ────────────────────────────────────────
WEATHER_CITIES=nyc,chicago,miami,los_angeles,denver

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./weatherbot.db

# ── Health check port ─────────────────────────────────────
PORT=8080
